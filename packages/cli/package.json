{
	"name": "lily-svelte",
	"version": "0.0.5",
	"description": "Add lily components to your project.",
	"license": "MIT",
	"author": {
		"name": "levish",
		"url": "https://levish-ac.pages.dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/levish0/lily-svelte.git",
		"directory": "packages/cli"
	},
	"type": "module",
	"bin": {
		"lily-svelte": "./dist/index.mjs"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		"./icons": {
			"types": "./dist/icons/index.d.mts",
			"default": "./dist/icons/index.mjs"
		},
		"./schema": {
			"types": "./dist/schema/index.d.mts",
			"default": "./dist/schema/index.mjs"
		},
		"./utils/css": {
			"types": "./dist/utils/css.d.mts",
			"default": "./dist/utils/css.mjs"
		},
		"./transformers": {
			"types": "./dist/utils/transformers/index.d.mts",
			"default": "./dist/utils/transformers/index.mjs"
		},
		"./transformers/icons": {
			"types": "./dist/utils/transformers/transform-icons.d.mts",
			"default": "./dist/utils/transformers/transform-icons.mjs"
		},
		"./transformers/imports": {
			"types": "./dist/utils/transformers/transform-imports.d.mts",
			"default": "./dist/utils/transformers/transform-imports.mjs"
		},
		"./transformers/menu": {
			"types": "./dist/utils/transformers/transform-menu.d.mts",
			"default": "./dist/utils/transformers/transform-menu.mjs"
		},
		"./transformers/font": {
			"types": "./dist/utils/transformers/transform-font.d.mts",
			"default": "./dist/utils/transformers/transform-font.mjs"
		},
		"./transformers/strip-types": {
			"types": "./dist/utils/transformers/transform-strip-types.d.mts",
			"default": "./dist/utils/transformers/transform-strip-types.mjs"
		},
		"./tailwind.css": {
			"style": "./dist/tailwind.css"
		}
	},
	"files": [
		"dist"
	],
	"keywords": [
		"components",
		"ui",
		"tailwind",
		"svelte",
		"sveltekit",
		"lily"
	],
	"scripts": {
		"dev": "tsdown --watch --sourcemap",
		"build": "tsdown --minify",
		"check": "tsc --noEmit",
		"start": "node dist/index.mjs",
		"start:dev": "cross-env REGISTRY_URL=http://localhost:5173/registry node dist/index.mjs"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"commander": "^14.0.0",
		"node-fetch-native": "^1.6.4",
		"postcss": "^8.5.5",
		"tailwind-merge": "^3.0.0"
	},
	"devDependencies": {
		"@clack/prompts": "^1.1.0",
		"@svecosystem/strip-types": "^0.0.4",
		"@sveltejs/acorn-typescript": "^1.0.5",
		"@types/node": "^25.9.3",
		"@types/semver": "^7.5.8",
		"acorn": "^8.15.0",
		"cross-env": "^7.0.3",
		"deepmerge": "^4.3.1",
		"empathic": "^1.1.0",
		"estree-walker": "^3.0.3",
		"get-tsconfig": "^4.7.3",
		"ignore": "^7.0.4",
		"magic-string": "^0.30.21",
		"memfs": "^4.17.2",
		"open": "^11.0.0",
		"package-manager-detector": "^1.2.0",
		"picocolors": "^1.1.1",
		"resolve.exports": "^2.0.3",
		"semver": "^7.7.1",
		"sucrase": "^3.35.0",
		"tinyexec": "^1.0.1",
		"tsdown": "^0.18.4",
		"type-fest": "^4.41.0",
		"typescript": "^6.0.3",
		"zod": "^4.3.6"
	}
}
