{
	"name": "docs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "pnpm build:registry && pnpm build:content && vite dev",
		"build": "pnpm build:registry && pnpm build:content && wrangler types && vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"build:registry": "tsx scripts/build-registry.ts build-registry",
		"build:content": "velite",
		"check": "pnpm build:registry && pnpm build:content && wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@iconify-json/heroicons": "^1",
		"@iconify/svelte": "^5",
		"@playwright/test": "^1.60.0",
		"@prettier/sync": "0.6.1",
		"@shikijs/langs": "^3.20.0",
		"@shikijs/themes": "^3.20.0",
		"@sveltejs/acorn-typescript": "^1.0.5",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"@internationalized/date": "^3.10.0",
		"@vitest/browser-playwright": "^4.1.8",
		"@zxcvbn-ts/core": "^3.0.4",
		"@zxcvbn-ts/language-common": "^3.0.4",
		"acorn": "^8.15.0",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"country-flag-icons": "^1.5.13",
		"embla-carousel-svelte": "^8.6.0",
		"estree-walker": "^3.0.3",
		"lily": "workspace:*",
		"magic-string": "^0.30.21",
		"mdsx": "^0.0.7",
		"package-manager-detector": "^1.6.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.61.0",
		"prettier-plugin-svelte": "^3.5.1",
		"rehype-pretty-code": "^0.14.1",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"shiki": "^3.20.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-sonner": "^1.1.0",
		"svelte-tel-input": "^4.2.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.20.6",
		"tw-animate-css": "^1.4.0",
		"unist-builder": "^4.0.0",
		"unist-util-visit": "^5.0.0",
		"velite": "^0.3.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"mode-watcher": "^1.1.0"
	}
}
