{
	"name": "docs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"build:registry": "tsx scripts/build-registry.ts build-registry",
		"check": "wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@sveltejs/acorn-typescript": "^1.0.5",
		"@sveltejs/adapter-cloudflare": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@vitest/browser-playwright": "^4.1.8",
		"acorn": "^8.15.0",
		"clsx": "^2.1.1",
		"estree-walker": "^3.0.3",
		"lily": "workspace:*",
		"playwright": "^1.60.0",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "catalog:",
		"tsx": "^4.20.6",
		"vite": "catalog:",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1",
		"zod": "catalog:"
	},
	"dependencies": {
		"mode-watcher": "^1.1.0"
	}
}
